<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="15.0" styleClass="content-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label styleClass="rpg-title" text="📖 Tomo della Saggezza (Regole di Gioco)" />
        <Separator />
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="20.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="20.0" top="10.0" />
                    </padding>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="rules-section-title" text="🏰 1. La Genesi (Creazione dell'Eroe)" />
                                <Label styleClass="rules-body" text="Tutto inizia forgiando un Eroe nella 'Taverna degli Eroi'. Ogni volta che un nuovo Eroe entra nel mondo, il fato genera per lui un intero ecosistema: 5 Nemici casuali, 3 Armi e 1 spaventoso Boss." wrapText="true" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="rules-section-title" text="⚒ 2. L'Armeria (Equipaggiamento)" />
                                <Label styleClass="rules-body" text="Un eroe non può brandire un'arma troppo potente per lui! Puoi equipaggiare solo armi il cui 'Livello' è MINORE o UGUALE ai punti EXP (Esperienza) del tuo Eroe. L'arma equipaggiata sommerà il suo potere al tuo Attacco base durante i combattimenti." wrapText="true" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="rules-section-title" text="⚔ 3. L'Arena (Combattimento base)" />
                                <Label styleClass="rules-body" text="Sfida i mostri nell'Arena per guadagnare Punti EXP. Attenzione: puoi sfidare solo nemici adeguati al tuo livello (Il gioco ti bloccherà se sei troppo debole). I combattimenti avvengono a turni automatici calcolando Attacco e Difesa." wrapText="true" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="rules-section-title" text="☠ 4. Permadeath (Morte Permanente)" />
                                <Label styleClass="rules-body" text="Non ci sono pozioni della resurrezione. Se i tuoi HP (Punti Vita) scendono a zero durante uno scontro, il tuo Eroe morirà e verrà cancellato per sempre dalla storia (e dal database!). Scegli le tue battaglie con saggezza." wrapText="true" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="rules-section-title" text="👑 5. La Stanza del Trono (Il Boss)" />
                                <Label styleClass="rules-body" text="Quando avrai accumulato abbastanza EXP massacrando nemici minori e trovato un'arma leggendaria, potrai tentare la sorte contro il Signore Oscuro. Sopravvivi, e il tuo nome riecheggerà per l'eternità." wrapText="true" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="rules-section-title" text="🎲 6. Strategia &amp; Fortuna" />
                                <Label styleClass="rules-body" text="Tutte le statistiche del mondo (Eroi, Nemici, Armi e Boss) sono generate casualmente: ogni partita è diversa! Se un Boss appare troppo ostico o non trovi armi adeguate, forgia un altro Eroe: il mondo genererà nuovi Nemici, nuove Armi e un nuovo Boss tra cui scegliere, aumentando le tue possibilità di trovare la combinazione vincente." wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
