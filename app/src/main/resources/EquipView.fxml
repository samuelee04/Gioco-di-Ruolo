<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg126355.View.EquipView">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <top>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" />
            </padding>
            <children>
                <Label text="⚔ Armeria - Equipaggiamento">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Label>
                <Separator prefWidth="200.0" />
            </children>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.6" BorderPane.alignment="CENTER">
            <items>
                <VBox prefHeight="200.0" prefWidth="100.0">
                    <children>
                        <Label text="🛡 Seleziona il tuo Eroe" />
                        <TableView fx:id="heroTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="hIdCol" prefWidth="75.0" text="ID" />
                                <TableColumn fx:id="hNameCol" prefWidth="75.0" text="NOME" />
                                <TableColumn fx:id="hAtkCol" prefWidth="75.0" text="ATK" />
                                <TableColumn fx:id="hExpCol" prefWidth="75.0" text="EXP" />
                                <TableColumn fx:id="hWeaponCol" prefWidth="75.0" text="ARMA" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
                <VBox prefHeight="200.0" prefWidth="100.0">
                    <children>
                        <Label text="⚔ Scegli un'Arma" />
                        <TableView fx:id="weaponTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="wNameCol" prefWidth="75.0" text="NOME" />
                                <TableColumn fx:id="wPowerCol" prefWidth="75.0" text="POWER" />
                                <TableColumn fx:id="wLevelCol" prefWidth="75.0" text="LEVEL" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <VBox BorderPane.alignment="CENTER">
            <children>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleEquip" text="⚔ EQUIPAGGIA ARMA SELEZIONATA ⚔">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="20.0" top="10.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </bottom>
</BorderPane>
